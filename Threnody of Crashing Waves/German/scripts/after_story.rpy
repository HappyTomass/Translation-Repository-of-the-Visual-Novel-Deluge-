    # a "You know what? Maybe we should go to Wallaby World tomorrow. The three of us, with Ina."
    a ""

# game/after_story.rpy:343
translate german dlc_2_75bb8cbf:

    # a "We'll make the most of this summer. Before you go back to school, and Ina goes off to college."
    a ""

