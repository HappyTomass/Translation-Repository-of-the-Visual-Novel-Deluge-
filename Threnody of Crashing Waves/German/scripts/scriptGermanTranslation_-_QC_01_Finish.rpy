    # game/script.rpy:352
    old "I had something more respectable in mind."
    new "Ich hatte mir etwas Respektableres vorgestellt." #decision:265 #next:271

    # game/script.rpy:352
    old "It's better than nothing. I'll take it."
    new "Es ist besser als Nichts. Ich nehm ihn." #decision:265 #next:277

    # game/script.rpy:634
    old "Sure thing. I'll keep my eyes wide open."
    new "Klar. Ich werde meine Augen weit offen halten." #decision:757 #next:763

    # game/script.rpy:634
    old "I really do have a lot of work to do."
    new "Ich habe echt viel zu tun." #decision:757 #next:769

    # game/script.rpy:904
    old "I can assure you I only had the purest of intentions!"
    new "Ich kann dir versichern, dass ich nur die besten Absichten hatte!" #decision:1249 #next:1255

    # game/script.rpy:904
    old "I have no idea what you're talking about—"
    new "Ich habe keine Ahnung, wovon du redest—" #decision:1249 #next:1261

    # game/script.rpy:977
    old "As she stood there, staring at me with a beaming smile, it was as if all her prior hostility had completely evaporated."
    new "Als sie mit einem strahlenden Lächeln so dastand, fühlte es sich danach an, als ob sich ihre gesamte Feindseligkeit in Luft aufgelöst hätte." #previous:1369 #decision:27370/27374 #next:1375/1381 #line:27366

    # game/script.rpy:977
    old "I wouldn't mind visiting your church some day."
    new "Ich würde eigentlich gerne mal deine Kirche besuchen." #decision:27366 #next:1375

    # game/script.rpy:977
    old "I should probably be on my best behavior when dealing with the pastor's daughter "
    new "Ich sollte wohl mein bestes Benehmen an den Tag legen, wenn ich es mit der Tochter des Pastors zu tun habe." #decision:27366 #next:1381

    # game/script.rpy:1153
    old "I thought I was just a paper boy."
    new "Ich dachte, dass ich nur ein Zeitungsjunge wäre." #decision:1747 #next:1753

    # game/script.rpy:1153
    old "Befriend Rika? I'd be glad to."
    new "Ich soll mich mit Rika anfreunden? Gerne doch." #decision:1747 #next:1771

    # game/script.rpy:1305
    old "No way. I'll definitely end with my head on a pike."
    new "Auf keinen Fall. Das endet doch nur damit, dass mein Kopf auf etwas Spitzem landen wird." #decision:2017 #next:2023

    # game/script.rpy:1305
    old "If you're sure no one will catch us—"
    new "Wenn du dir sicher bist, dass uns niemand erwischt—" #decision:2017 #next:2071

    # game/script.rpy:1867
    old "I'd be glad to — if I survive my paper round."
    new "Sehr gerne — sofern ich meine Zeitungsrunde überlebe." #decision:2923 #next:2929

    # game/script.rpy:1867
    old "This town has restaurants?"
    new "Diese Stadt hat Restaurants?" #decision:2923 #next:2935

    # game/script.rpy:1931
    old "I didn't really {i}get{/i} anything out of Rika . . ."
    new "Ich habe nicht wirklich etwas aus Rika {i}herausbekommen{/i} . . ." #decision:2977 #next:2983

    # game/script.rpy:1931
    old "She complimented you on your journalism."
    new "Sie hat dir ein Kompliment für deine journalistische Arbeit gemacht." #decision:2977 #next:2995

    # game/script.rpy:2734
    old "I'm sorry, I wasn't listening."
    new "Tut mir leid, ich hab gerade nicht zugehört." #decision:4489 #next:4495

    # game/script.rpy:2734
    old "Sounds pretty tame if they got in trouble for this."
    new "Klingt merkwürdig, dass sie für sowas harmloses in Schwierigkeiten geraten sind." #decision:4489 #next:4501

    # game/script.rpy:3057
    old "Not really."
    new "Nicht wirklich." #decision:5125 #next:5131

    # game/script.rpy:3057
    old "Is there anything else you'd like to {i}tell{/i} me?"
    new "Gibt es denn noch etwas, das du mir {i}erzählen{/i} möchtest?" #decision:5125 #next:5149

    # game/script.rpy:3262
    old "She was pointing at a crude s-shaped pictogram, engraved into the surface of one of the rocks."
    new "Sie zeigte auf ein grobes S-förmiges Piktogramm, welches in einem der Steine eingraviert war." #previous:5467 #next:5473/5479 #decision:27430/27434 #line:27426

    # game/script.rpy:3262
    old "It {i}does{/i} look like an S."
    new "Es sieht {i}wirklich{/i} wie ein S aus." #decision:27426 #next:5473

    # game/script.rpy:3262
    old "Abbotford's spelling ace is at it again."
    new "Abbotsfords Rechtschreib-Ass schlägt wieder zu." #decision:27426 #next:5479

    # game/script.rpy:3403
    old "Will you come with me?"
    new "Wirst du mit mir dort hingehen?" #previous:5773 #decision:27442/27446 #line:27438

    # game/script.rpy:3403
    old "I'd love to."
    new "Sehr gerne." #decision:27438 #next:5779

    # game/script.rpy:3403
    old "It's really time to get you to bed."
    new "Es wird wirklich Zeit, dass du ins Bett gehst." #decision:27438 #next:5791

    # game/script.rpy:3805
    old "I thought back to Sunday evening — and the words Mei had drowsily muttered into my ear."
    new "Ich dachte zurück an Sonntagabend — und an die Worte, die Mei mir schläfrig ins Ohr gemurmelt hatte." #previous:6367 #next:27454/27458 #decision: #line:27450

    # game/script.rpy:3805
    old "I don't see how this is any of your business."
    new "Ich verstehe nicht, warum dich das was angehen sollte." #decision:27450 #next:6373

    # game/script.rpy:3805
    old "It was just a wild idea of hers—"
    new "Das war lediglich eine verrückte Idee von ihr—" #decision:27450 #next:6385

    # game/script.rpy:3964
    old "Can you at least tell me the name of the author?"
    new "Kannst du mir zumindest den Namen des Autors nennen?" #previous:6649 #decision:27466/27470 #line:27462

    # game/script.rpy:3964
    old "I'm sorry, I really have no clue."
    new "Es tut mir leid, ich habe echt keine Ahnung." #decision:27462 #next:6655

    # game/script.rpy:3964
    old "I believe he was called, eh— Spangler?"
    new "Ich glaube, er hieß, ähm— Spangler?" #decision:27462 #next:6697

    # game/script.rpy:4356
    old "No, I'm taking Rika and Mei to the shore after school."
    new "Nein, ich gehe mit Rika und Mei nach der Schule an den Strand." #decision:7639 #next:7645

    # game/script.rpy:4356
    old "I'm afraid I have a lot of studying to do—"
    new "Ich fürchte, dass ich leider viel lernen muss—" #decision:7639 #next:7669

    # game/script.rpy:4525
    old "Such grace, I've never seen anything like it."
    new "Das sieht so schön aus; ich habe so was noch nie gesehen." #decision:7951 #next:7957

    # game/script.rpy:4525
    old "She's alright—"
    new "Sie ist ganz in Ordnung—" #decision:7951 #next:7975

    # game/script.rpy:4620
    old "We'd better call the emergency services."
    new "Wir sollten den Notruf wählen." #decision:8149 #next:8155

    # game/script.rpy:4620
    old "We need to dive in to look for her."
    new "Wir sollten ins Wasser gehen und nach ihr schauen." #decision:8149 #next:8167

    # game/script.rpy:5010
    old "Sounds pretty foolproof to me."
    new "Erscheint mir narrensicher." #decision:8827 #next:8833

    # game/script.rpy:5010
    old "Wouldn't that constitute a felony?"
    new "Würde das nicht ein Verbrechen sein?" #decision:8827 #next:8839

    # game/script.rpy:5849
    old "I didn't, I swear."
    new "Wirklich nicht, ich schwöre." #decision:10309 #next:10315

